
   mVec ?= mod.load('vector')

-- Tolerance for floating point comparisons.  Colour conversions involving transcendental functions
-- (e.g. pow, cos, sin) accumulate small errors, so we allow a tolerance of 0.005 (~1.3/255).

TOLERANCE = 0.005

function near(A, B)
   return math.abs(A - B) < TOLERANCE
end

function checkRGB(Painter, Red, Green, Blue, Alpha)
   local rgb = Painter.colour
   if not near(Red, rgb.red) then print(f'Red mismatch: expected {Red}, got {rgb.red}') return false end
   if not near(Green, rgb.green) then print(f'Green mismatch: expected {Green}, got {rgb.green}') return false end
   if not near(Blue, rgb.blue) then print(f'Blue mismatch: expected {Blue}, got {rgb.blue}') return false end
   if not near(Alpha, rgb.alpha) then print(f'Alpha mismatch: expected {Alpha}, got {rgb.alpha}') return false end
   return true
end

function checkCIE(Painter, X, Y, Z, Alpha)
   local cie = Painter.cie
   if not near(X, cie.x) then print(f'CIE X mismatch: expected {X}, got {cie.x}') return false end
   if not near(Y, cie.y) then print(f'CIE Y mismatch: expected {Y}, got {cie.y}') return false end
   if not near(Z, cie.z) then print(f'CIE Z mismatch: expected {Z}, got {cie.z}') return false end
   if not near(Alpha, cie.alpha) then print(f'CIE Alpha mismatch: expected {Alpha}, got {cie.alpha}') return false end
   return true
end

-----------------------------------------------------------------------------------------------------------------------
-- rgb() and rgba()
-----------------------------------------------------------------------------------------------------------------------

@Test function ReadRGB()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgb(255,128,0)", painter)
   assert(checkRGB(painter, 1.0, 128/255, 0, 1.0), 'Failed rgb(255,128,0)')
end

@Test function ReadRGBWithAlpha()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgb(255,255,255,0.5)", painter)
   assert(checkRGB(painter, 1.0, 1.0, 1.0, 0.5), 'Failed rgb() with alpha')
end

@Test function ReadRGBA()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgba(0,0,0,0.75)", painter)
   assert(checkRGB(painter, 0, 0, 0, 0.75), 'Failed rgba()')
end

@Test function ReadRGBPercentage()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgb(100%,50%,0%)", painter)
   assert(checkRGB(painter, 1.0, 0.5, 0, 1.0), 'Failed rgb() with percentages')
end

@Test function ReadRGBBlack()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgb(0,0,0)", painter)
   assert(checkRGB(painter, 0, 0, 0, 1.0), 'Failed rgb() black')
end

