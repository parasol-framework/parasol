@Test function LeadingSemicolon()
   -- ReadPainter() should skip a leading semicolon
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, ";rgb(255,0,0)", painter)
   assert(checkRGB(painter, 1.0, 0, 0, 1.0), 'Failed to skip leading semicolon')
end

@Test function LeadingWhitespace()
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "  rgb(0,255,0)", painter)
   assert(checkRGB(painter, 0, 1.0, 0, 1.0), 'Failed to skip leading whitespace')
end

@Test function InvalidColourName()
   painter = struct.new('VectorPainter')
   local err = mVec.ReadPainter(nil, "notacolour", painter)
   assert(err != ERR_Okay, 'Invalid colour name should return an error')
end

@Test function InvalidHexLength()
   painter = struct.new('VectorPainter')
   local err = mVec.ReadPainter(nil, "#ab", painter)
   assert(err != ERR_Okay, 'Hex with 2 nibbles should return an error')
end

-----------------------------------------------------------------------------------------------------------------------
-- Cross-verification: equivalent colours in different formats produce the same result
-----------------------------------------------------------------------------------------------------------------------

@Test function CrossVerifyRedFormats()
   -- Pure red expressed in multiple formats should produce near-identical RGB values
   local formats = {
      "rgb(255,0,0)",
      "#ff0000",
      "red",
      "hsl(0,100,50)"
   }

   local results = {}
   for i, fmt in ipairs(formats) do
      local p = struct.new('VectorPainter')
      check mVec.ReadPainter(nil, fmt, p)
      results[i] = p
   end

   for i = 0, #results - 2 do
      local a = results[i].colour
      local b = results[i + 1].colour
      assert(near(a.red, b.red) and near(a.green, b.green) and near(a.blue, b.blue),
         f'Red cross-check failed between format {i} and {i+1}')
   end
end

@Test function CrossVerifyWhiteCIE_sRGB()
   -- White expressed via sRGB-based colour spaces should produce matching CIE XYZ values.
   -- These all go through the sRGB-to-XYZ matrix path.
   local formats = {
      "rgb(255,255,255)",
      "#ffffff",
      "white",
      "hsl(0,0,100)",
      "oklab(1 0 0)",
      "oklch(1 0 0)"
   }

   local results = {}
   for i, fmt in ipairs(formats) do
      local p = struct.new('VectorPainter')
      check mVec.ReadPainter(nil, fmt, p)
      results[i] = p
   end

   for i = 0, #results - 2 do
      local a = results[i].cie
      local b = results[i + 1].cie
      assert(near(a.x, b.x) and near(a.y, b.y) and near(a.z, b.z),
         f'White CIE cross-check (sRGB group) failed between format {i} and {i+1}')
   end
end

@Test function CrossVerifyWhiteCIE_Lab()
   -- White expressed via CIE Lab colour spaces should produce matching CIE XYZ values.
   -- These go through the D50-to-D65 Bradford adaptation path.
   local formats = {
      "lab(100 0 0)",
      "lch(100 0 0)"
   }

   local results = {}
   for i, fmt in ipairs(formats) do
      local p = struct.new('VectorPainter')
      check mVec.ReadPainter(nil, fmt, p)
      results[i] = p
   end

   local a = results[0].cie
   local b = results[1].cie
   assert(near(a.x, b.x) and near(a.y, b.y) and near(a.z, b.z),
      'White CIE cross-check (Lab group) failed between lab() and lch()')
end
