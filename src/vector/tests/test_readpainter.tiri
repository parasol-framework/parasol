@Test function ReadLabMidGrey()
   -- lab(50 0 0) should produce a mid-grey
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "lab(50 0 0)", painter)
   local rgb = painter.colour
   assert(near(rgb.red, rgb.green) and near(rgb.green, rgb.blue), 'lab() mid-grey: channels should be equal')
   assert(rgb.red > 0.1 and rgb.red < 0.9, f'lab() mid-grey: expected mid value, got {rgb.red}')
end

@Test function ReadLabRed()
   -- lab(54.29 80.81 69.89) is approximately sRGB red (#ff0000)
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "lab(54.29 80.81 69.89)", painter)
   assert(near(painter.colour.red, 1.0), f'lab() red channel: expected ~1.0, got {painter.colour.red}')
   assert(near(painter.colour.green, 0.0), f'lab() green channel: expected ~0.0, got {painter.colour.green}')
   assert(near(painter.colour.blue, 0.0), f'lab() blue channel: expected ~0.0, got {painter.colour.blue}')
end

