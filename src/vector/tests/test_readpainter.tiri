@Test function ReadOKLabRed()
   -- oklab(0.6279 0.2249 0.1264) is approximately sRGB red
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "oklab(0.6279 0.2249 0.1264)", painter)
   assert(near(painter.colour.red, 1.0), f'oklab() red: expected ~1.0, got {painter.colour.red}')
   assert(near(painter.colour.green, 0.0), f'oklab() green: expected ~0.0, got {painter.colour.green}')
   assert(near(painter.colour.blue, 0.0), f'oklab() blue: expected ~0.0, got {painter.colour.blue}')
end

