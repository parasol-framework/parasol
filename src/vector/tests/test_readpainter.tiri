-----------------------------------------------------------------------------------------------------------------------
-- CIE XYZ storage verification
-----------------------------------------------------------------------------------------------------------------------

@Test function CIEFromRGB()
   -- Verify that CIE XYZ is populated when parsing rgb().
   -- sRGB white (1,1,1) should give the D65 white point: X≈0.9505, Y≈1.0, Z≈1.0890
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgb(255,255,255)", painter)
   assert(checkCIE(painter, 0.9505, 1.0, 1.0283, 1.0), 'CIE XYZ from rgb() white is incorrect')
end

@Test function CIEFromHex()
   -- sRGB black should give CIE XYZ (0, 0, 0)
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "#000000", painter)
   assert(checkCIE(painter, 0, 0, 0, 1.0), 'CIE XYZ from hex black is incorrect')
end

@Test function CIEFromNamed()
   -- Named white should match D65 white point
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "white", painter)
   assert(checkCIE(painter, 0.9505, 1.0, 1.0283, 1.0), 'CIE XYZ from named "white" is incorrect')
end

@Test function CIEFromOKLab()
   -- oklab() white (1 0 0): verify CIE XYZ is also the D65 white point
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "oklab(1 0 0)", painter)
   assert(checkCIE(painter, 0.9505, 1.0, 1.0283, 1.0), 'CIE XYZ from oklab() white is incorrect')
end

@Test function CIEFromLab()
   -- lab(100 0 0) white: CIE XYZ via D50-to-D65 Bradford adaptation.
   -- The Bradford transform produces slightly different values to the direct sRGB matrix path.
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "lab(100 0 0)", painter)
   assert(checkCIE(painter, 0.9505, 1.0, 1.0889, 1.0), 'CIE XYZ from lab() white is incorrect')
end

@Test function CIEAlphaFromRGBA()
   -- Verify that CIE alpha matches the input alpha
   painter = struct.new('VectorPainter')
   check mVec.ReadPainter(nil, "rgba(255,0,0,0.3)", painter)
   assert(near(painter.cie.alpha, 0.3), f'CIE alpha mismatch: expected 0.3, got {painter.cie.alpha}')
end

